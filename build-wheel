#!/bin/bash
# Build a fastled wheel that bundles the Rust CLI binary as a wheel script.
#
# Maturin's pyo3-binding mode produces the `_native` extension module but
# doesn't ship Rust [[bin]] targets in the wheel. We work around that by
# compiling the binary first, dropping it into `wheel-data/scripts/`, and
# letting maturin package that directory as the wheel's `.data/` tree (see
# `[tool.maturin] data` in pyproject.toml). Pip extracts `data/scripts/*`
# to the venv's Scripts/ (Windows) or bin/ (Unix) on install.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# Platform-specific binary name and target directory.
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*) EXE_NAME="fastled.exe" ;;
  *)                    EXE_NAME="fastled" ;;
esac

echo "Compiling fastled CLI (release)..."
if command -v soldr &> /dev/null; then
  soldr cargo build --release --bin fastled
else
  echo "Warning: soldr not found; falling back to plain cargo (slow). Install with: uv tool install soldr"
  cargo build --release --bin fastled
fi

# Resolve where cargo wrote the binary. cargo on Windows MSVC writes the
# binary under a triple subdir.
if [[ -n "${CARGO_BUILD_TARGET:-}" ]]; then
  BIN_SRC="$SCRIPT_DIR/target/${CARGO_BUILD_TARGET}/release/${EXE_NAME}"
else
  BIN_SRC="$SCRIPT_DIR/target/release/${EXE_NAME}"
fi

# On Windows the rustup default host triple is MSVC; the binary lands under
# target/<triple>/release/ even when CARGO_BUILD_TARGET isn't set.
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*)
    ARCH="$(uname -m)"
    if [[ "$ARCH" = "x86_64" ]]; then
      TARGET_TRIPLE="x86_64-pc-windows-msvc"
    else
      TARGET_TRIPLE="aarch64-pc-windows-msvc"
    fi
    BIN_SRC="$SCRIPT_DIR/target/${TARGET_TRIPLE}/release/${EXE_NAME}"
    ;;
esac

if [[ ! -f "$BIN_SRC" ]]; then
  echo "Error: built binary not found at $BIN_SRC" >&2
  exit 1
fi

WHEEL_DATA_DIR="$SCRIPT_DIR/wheel-data/scripts"
mkdir -p "$WHEEL_DATA_DIR"
cp -f "$BIN_SRC" "$WHEEL_DATA_DIR/$EXE_NAME"
echo "Staged $BIN_SRC -> $WHEEL_DATA_DIR/$EXE_NAME"

echo "Building wheel..."
uv run maturin build --release "$@"
