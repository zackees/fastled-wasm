#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# Rust tests (skip if cargo not available)
if command -v cargo &> /dev/null; then
  "$SCRIPT_DIR/_cargo" test --workspace
else
  echo "WARNING: cargo not found, skipping Rust tests"
fi

uv run pytest -x -v -s --durations=0 tests/unit "$@"
