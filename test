#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# Rust tests go through soldr so the zccache compile cache is hit.
# Install soldr with: uv tool install soldr  (or see zackees/soldr).
if ! command -v soldr &> /dev/null; then
  echo "Error: soldr is required for Rust tests. Install with: uv tool install soldr" >&2
  exit 1
fi
soldr cargo test --workspace

uv run pytest -x -v -s --durations=0 tests/unit "$@"
