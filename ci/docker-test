#!/bin/bash
# Fast local Linux CI validation.
#
# Usage:
#   bash ci/docker-test              # build + lint + test
#   bash ci/docker-test lint         # lint only
#   bash ci/docker-test test         # test only
#   bash ci/docker-test build        # install + cargo check only
#
# Uses a cached Docker image with pre-installed system deps and Rust.
# Copies source into the container (no volume mount) to avoid
# cross-platform .venv and target/ conflicts.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
IMAGE_NAME="fastled-linux-test"

cd "$PROJECT_ROOT"

# Build the base image (cached unless Dockerfile changes)
echo "==> Building Docker image (cached)..."
docker build -q -t "$IMAGE_NAME" -f ci/Dockerfile.linux-test .

TASK="${1:-all}"

case "$TASK" in
  build)
    CMD="./install"
    ;;
  lint)
    CMD="./install && ./lint"
    ;;
  test)
    CMD="./install && ./test"
    ;;
  all)
    CMD="./install && ./lint && ./test"
    ;;
  *)
    echo "Usage: $0 [build|lint|test|all]"
    exit 1
    ;;
esac

# Use --tmpfs for .venv and target to avoid volume mount conflicts.
# Copy source code into container instead of mounting.
echo "==> Running: $TASK"
docker run --rm \
  -v "$PROJECT_ROOT:/src:ro" \
  -w /work \
  "$IMAGE_NAME" \
  bash -c "cp -a /src/. /work/ && $CMD"
