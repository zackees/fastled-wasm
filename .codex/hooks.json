{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ci/hooks/tool_guard",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "ci/hooks/tool_guard",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "functions.shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "ci/hooks/tool_guard",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
