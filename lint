#!/bin/bash
set -e

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# Rust linting (skip if cargo not available)
if command -v cargo &> /dev/null; then
  echo Running cargo fmt check
  "$SCRIPT_DIR/_cargo" fmt --all --check
  echo Running cargo clippy
  "$SCRIPT_DIR/_cargo" clippy --workspace --all-targets -- -D warnings
else
  echo "WARNING: cargo not found, skipping Rust linting"
fi

echo Running ruff src
uv run ruff check --fix src
echo Running ruff tests
uv run ruff check --fix tests
echo Running black src tests
uv run black src tests
echo Running isort src tests
uv run isort --profile black src tests
echo Running pyright src tests
uv run pyright src tests
echo Running keyboard interrupt checker src tests
uv run python ci/lint_python/keyboard_interrupt_checker.py src tests
echo Linting complete!
exit 0
