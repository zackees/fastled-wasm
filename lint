#!/bin/bash
set -e

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# Rust linting (skip if cargo not available)
if command -v cargo &> /dev/null; then
  echo Running cargo fmt check
  "$SCRIPT_DIR/_cargo" fmt --all --check
  echo Running cargo clippy
  "$SCRIPT_DIR/_cargo" clippy --workspace --all-targets -- -D warnings
else
  echo "WARNING: cargo not found, skipping Rust linting"
fi

echo Running ruff src compiler
uv run ruff check --fix src compiler
echo Running ruff tests compiler
uv run ruff check --fix tests compiler
echo Running black src tests compiler
uv run black src tests compiler
echo Running isort src tests compiler
uv run isort --profile black src tests compiler
echo Running pyright src tests compiler
uv run pyright src compiler tests
echo Running keyboard interrupt checker src tests compiler
uv run python ci/lint_python/keyboard_interrupt_checker.py src tests compiler
echo Linting complete!
exit 0
